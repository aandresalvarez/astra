#!/usr/bin/env python3
"""
stanford-graph-mail - read-only Microsoft Graph mail helper via Graph PowerShell.

Commands:
  stanford-graph-mail login
  stanford-graph-mail logout
  stanford-graph-mail accounts
  stanford-graph-mail folders
  stanford-graph-mail search --query "term" [--limit 10]
  stanford-graph-mail get --message-id MESSAGE_ID
"""

import argparse
import json
import os
import subprocess
import sys
import urllib.parse


DEFAULT_TENANT = os.environ.get("ASTRA_GRAPH_MAIL_TENANT", "stanfordhealthcare.org").strip() or "stanfordhealthcare.org"
DEFAULT_ACCOUNT = os.environ.get("ASTRA_GRAPH_MAIL_ACCOUNT", "").strip()
DEFAULT_DOMAIN = os.environ.get("ASTRA_GRAPH_MAIL_DOMAIN", "stanfordhealthcare.org").strip().lower().lstrip("@")
POWERSHELL = os.environ.get("ASTRA_GRAPH_MAIL_PWSH", "pwsh")
SCOPES = '"User.Read","Mail.Read"'


class MailToolError(Exception):
    pass


def ps_quote(value):
    return "'" + str(value).replace("'", "''") + "'"


def graph_url(path, query=None):
    url = "https://graph.microsoft.com/v1.0" + path
    if query:
        url += "?" + urllib.parse.urlencode(query)
    return url


def run_powershell(script, timeout=60, capture=True):
    command = [POWERSHELL, "-NoProfile", "-Command", script]
    try:
        result = subprocess.run(
            command,
            text=True,
            capture_output=capture,
            timeout=timeout,
            check=False,
        )
    except FileNotFoundError:
        raise MailToolError("PowerShell is not installed. Install with: brew install powershell")
    except subprocess.TimeoutExpired:
        raise MailToolError(
            "Microsoft Graph PowerShell did not return in time. "
            "Run `stanford-graph-mail login` first and complete browser sign-in."
        )

    if result.returncode != 0:
        stderr = result.stderr.strip() if capture else ""
        stdout = result.stdout.strip() if capture else ""
        detail = stderr or stdout or f"exit {result.returncode}"
        raise MailToolError(detail)
    return result.stdout if capture else ""


def graph_get(tenant, url, prefer_text_body=False, consistency_level_eventual=False):
    headers = []
    if prefer_text_body:
        headers.append("$headers['Prefer'] = 'outlook.body-content-type=\"text\"'")
    if consistency_level_eventual:
        headers.append("$headers['ConsistencyLevel'] = 'eventual'")

    header_script = "\n".join(headers)
    script = f"""
$ErrorActionPreference = 'Stop'
Import-Module Microsoft.Graph.Authentication
Connect-MgGraph -TenantId {ps_quote(tenant)} -Scopes {SCOPES} -NoWelcome | Out-Null
$headers = @{{}}
{header_script}
if ($headers.Count -gt 0) {{
  $result = Invoke-MgGraphRequest -Method GET -Uri {ps_quote(url)} -Headers $headers
}} else {{
  $result = Invoke-MgGraphRequest -Method GET -Uri {ps_quote(url)}
}}
$result | ConvertTo-Json -Depth 32 -Compress
"""
    output = run_powershell(script, timeout=75, capture=True).strip()
    if not output:
        raise MailToolError("Microsoft Graph returned no output.")
    return json.loads(output)


def print_json(payload):
    print(json.dumps(payload, indent=2, sort_keys=True))


def current_account(tenant):
    return graph_get(tenant, graph_url("/me", {"$select": "id,displayName,userPrincipalName,mail"}))


def account_label(payload):
    return payload.get("mail") or payload.get("userPrincipalName") or payload.get("displayName") or "unknown account"


def account_aliases(payload):
    return {
        str(value).strip().lower()
        for value in [
            payload.get("mail"),
            payload.get("userPrincipalName"),
        ]
        if value
    }


def validate_account(args, payload=None):
    payload = payload or current_account(args.tenant)
    aliases = account_aliases(payload)
    expected_domain = (getattr(args, "domain", None) or DEFAULT_DOMAIN).strip().lower().lstrip("@")

    if expected_domain and not any(alias.endswith("@" + expected_domain) for alias in aliases):
        raise MailToolError(
            f"Signed-in Graph account is {account_label(payload)!r}, not an @{expected_domain} mailbox. "
            "Run `stanford-graph-mail logout`, then run `stanford-graph-mail login` with your Stanford Health Care account."
        )

    if args.account:
        requested = args.account.strip().lower()
        if requested not in aliases:
            raise MailToolError(
                f"Signed-in Graph account is {account_label(payload)!r}, not {args.account!r}. "
                "Run `stanford-graph-mail logout`, then run `stanford-graph-mail login` again."
            )
    return payload


def cmd_login(args):
    payload = validate_account(args, current_account(args.tenant))
    print_json({
        "account": {
            "displayName": payload.get("displayName"),
            "mail": payload.get("mail"),
            "userPrincipalName": payload.get("userPrincipalName"),
            "tenant": args.tenant,
        },
        "status": "signed-in",
    })


def cmd_logout(_args):
    script = """
$ErrorActionPreference = 'Stop'
Import-Module Microsoft.Graph.Authentication
try {
  Connect-MgGraph -Scopes "User.Read" -NoWelcome | Out-Null
} catch {
}
Disconnect-MgGraph | Out-Null
"""
    run_powershell(script, timeout=30, capture=True)
    print_json({"status": "signed-out"})


def cmd_accounts(args):
    payload = validate_account(args, current_account(args.tenant))
    print_json({
        "accounts": [{
            "displayName": payload.get("displayName"),
            "id": payload.get("id"),
            "mail": payload.get("mail"),
            "tenant": args.tenant,
            "userPrincipalName": payload.get("userPrincipalName"),
        }]
    })


def cmd_folders(args):
    validate_account(args)
    url = graph_url(
        "/me/mailFolders",
        {
            "$top": str(max(1, min(args.limit, 100))),
            "$select": "id,displayName,totalItemCount,unreadItemCount",
        },
    )
    print_json(graph_get(args.tenant, url))


def cmd_search(args):
    validate_account(args)
    limit = str(max(1, min(args.limit, 25)))
    query = {
        "$top": limit,
        "$select": "id,subject,from,receivedDateTime,bodyPreview,hasAttachments,webLink",
    }
    consistency = False
    if args.query:
        query["$search"] = f'"{args.query}"'
        consistency = True
    else:
        query["$orderby"] = "receivedDateTime desc"
    url = graph_url("/me/messages", query)
    print_json(graph_get(args.tenant, url, consistency_level_eventual=consistency))


def cmd_get(args):
    validate_account(args)
    message_id = urllib.parse.quote(args.message_id, safe="")
    url = graph_url(
        f"/me/messages/{message_id}",
        {
            "$select": "id,subject,from,toRecipients,ccRecipients,receivedDateTime,sentDateTime,body,hasAttachments,webLink",
        },
    )
    print_json(graph_get(args.tenant, url, prefer_text_body=True))


def build_parser():
    parser = argparse.ArgumentParser(description="Read Stanford Health Care Microsoft 365 mail via Graph PowerShell.")
    parser.add_argument("--tenant", default=DEFAULT_TENANT, help="Microsoft 365 tenant domain. Defaults to stanfordhealthcare.org.")
    parser.add_argument("--account", default=DEFAULT_ACCOUNT, help="Optional expected signed-in mailbox. If omitted, commands require any @stanfordhealthcare.org Graph account.")
    parser.add_argument("--domain", default=DEFAULT_DOMAIN, help=argparse.SUPPRESS)
    subparsers = parser.add_subparsers(dest="command", required=True)

    login = subparsers.add_parser("login")
    login.set_defaults(func=cmd_login)

    logout = subparsers.add_parser("logout")
    logout.set_defaults(func=cmd_logout)

    accounts = subparsers.add_parser("accounts")
    accounts.set_defaults(func=cmd_accounts)

    folders = subparsers.add_parser("folders")
    folders.add_argument("--limit", type=int, default=50)
    folders.set_defaults(func=cmd_folders)

    search = subparsers.add_parser("search")
    search.add_argument("--query", default="")
    search.add_argument("--limit", type=int, default=10)
    search.set_defaults(func=cmd_search)

    get = subparsers.add_parser("get")
    get.add_argument("--message-id", required=True)
    get.set_defaults(func=cmd_get)

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()
    try:
        args.func(args)
    except json.JSONDecodeError as error:
        print(f"stanford-graph-mail: invalid Microsoft Graph response: {error}", file=sys.stderr)
        return 1
    except MailToolError as error:
        print(f"stanford-graph-mail: {error}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
